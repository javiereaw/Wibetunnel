WIBE_TOKEN=tu_token_secreto_aqui
WIBE_PORT=4020
WIBE_SHELL=powershell.exe
WIBE_CWD=C:\www
WIBE_SHORTCUTS=
WIBE_MAX_SESSIONS=5

# Seguridad
WIBE_RATE_MAX=5
WIBE_RATE_WINDOW=15
WIBE_TIMEOUT=0

# Reconexion persistente y cross-device (segundos, 1800 = 30 min)
WIBE_RECONNECT_GRACE=1800
WIBE_BUFFER_SIZE=51200

# HTTPS (opcional, dejar vacio para HTTP)
WIBE_SSL_CERT=
WIBE_SSL_KEY=

# Origenes CORS adicionales (ej. dominio de Cloudflare tunnel, separados por coma)
WIBE_ALLOWED_ORIGINS=
